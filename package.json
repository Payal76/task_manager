{
  "name": "task-manager",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "install-all": "npm install --workspaces",
    "start": "concurrently \"npm run start --workspace server\" \"npm run dev --workspace client\"",
    "start:server": "npm run start --workspace server",
    "start:client": "npm run dev --workspace client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
